{
  "name": "video-translator",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.videotranslator.app",
    "files": [
      "**/*",
      "python/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      }
    ]
  }
}